# ──────────────────────────────────────────────────────────────────────────────
# AvaRamp — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Neon PostgreSQL — https://console.neon.tech → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# Redis — local or Upstash
REDIS_URL=redis://localhost:6379

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
GLACIER_API_KEY=

# HD wallet mnemonic (12 words, BIP-39)
HD_MNEMONIC=

# 32-byte hex key for AES-256-GCM private key encryption
ENCRYPTION_KEY=

# JWT signing secret (min 32 chars)
JWT_SECRET=

# M-Pesa Daraja — https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=600000
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
MPESA_B2C_RESULT_URL=https://your-domain.com/api/mpesa/b2c/result
MPESA_B2C_TIMEOUT_URL=https://your-domain.com/api/mpesa/b2c/timeout
