# ──────────────────────────────────────────────────────────────────────────────
# AvaRamp — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Neon PostgreSQL — https://console.neon.tech → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# Redis — local or Upstash
REDIS_URL=redis://localhost:6379

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
GLACIER_API_KEY=

# HD wallet mnemonic (12 words, BIP-39)
HD_MNEMONIC=

# 32-byte hex key for AES-256-GCM private key encryption
ENCRYPTION_KEY=

# JWT signing secret (min 32 chars)
JWT_SECRET=

# Paystack — https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_URL=https://your-domain.com/paystack/webhook
# Set true to skip real disbursements during local dev
PAYSTACK_SKIP_SETTLEMENT=false
