# ──────────────────────────────────────────────────────────────────────────────
# AvaRamp — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://avaramp:avaramp_secret@localhost:5432/avaramp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Avalanche / Glacier ───────────────────────────────────────────────────────
# Glacier API key — https://glacier.docs.avax.network
GLACIER_API_KEY=
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/ws

# ── Wallet / Keys ─────────────────────────────────────────────────────────────
# Operator hot wallet private key (hex, no 0x prefix)
OPERATOR_PRIVATE_KEY=
# BIP-39 mnemonic for HD wallet deposit address derivation (12 or 24 words)
HD_MNEMONIC=

# ── Smart Contracts ───────────────────────────────────────────────────────────
PAYMENT_GATEWAY_ADDRESS=

# ── M-Pesa (Safaricom Daraja API) ─────────────────────────────────────────────
# From https://developer.safaricom.co.ke — use sandbox credentials for testing
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Business short code assigned to your Daraja app
MPESA_SHORTCODE=
# Initiator name from the Daraja portal
MPESA_INITIATOR_NAME=
# Base64-encoded encrypted security credential (generate via Daraja portal)
MPESA_SECURITY_CREDENTIAL=
# Publicly reachable URLs for M-Pesa B2C async callbacks
MPESA_B2C_RESULT_URL=https://your-domain.com/api/mpesa/result
MPESA_B2C_TIMEOUT_URL=https://your-domain.com/api/mpesa/timeout

# ── Security ──────────────────────────────────────────────────────────────────
# 64-char hex string (32 bytes) for AES-256-GCM encryption of deposit private keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Minimum 32 characters — used to sign JWT access tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
