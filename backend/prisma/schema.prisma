generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?
  passwordHash String?
  kycStatus    KycStatus @default(PENDING)
  role         UserRole  @default(USER)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  payments     Payment[]
  consents     ConsentRecord[]
  merchant     Merchant?
}

model Merchant {
  id               String    @id @default(uuid())
  userId           String?   @unique
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  email            String    @unique
  walletAddress    String    @unique
  // Payout destination — phone (personal M-Pesa/MoMo), till (business till), or paybill
  payoutType       String    @default("till")   // "phone" | "till" | "paybill"
  payoutAccount    String                        // phone number, till number, or paybill number
  payoutAccountRef String?                       // paybill account reference (e.g. account name/number)
  payoutCurrency   String    @default("KES")     // KES | NGN | GHS | TZS | UGX
  mpesaTill        String                        // kept for backward compatibility
  webhookUrl       String?
  webhookSecret    String
  feeOverrideBps   Int?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payments         Payment[]
}

model Payment {
  id              String          @id @default(uuid())
  idempotencyKey  String?         @unique
  merchantId      String
  merchant        Merchant        @relation(fields: [merchantId], references: [id])
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  amountUsdc      String
  amountFiat      String
  fiatCurrency    String
  phone           String?
  reference       String?
  depositAddress  String          @unique
  depositPk       String
  status          PaymentStatus   @default(PENDING)
  expiresAt       DateTime
  confirmedTxHash String?
  confirmedAt     DateTime?
  onChainAmount   String?
  fxRate          Float?
  fiatAmount      String?
  mpesaReceiptId  String?
  settledAt       DateTime?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  transactions    Transaction[]
  ledgerEntries   LedgerEntry[]
  webhooks        WebhookDelivery[]
}

model Transaction {
  id          String   @id @default(uuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id])
  txHash      String   @unique
  blockNumber Int
  fromAddress String
  toAddress   String
  amount      String
  token       String   @default("USDC")
  chainId     Int      @default(43114)
  createdAt   DateTime @default(now())

  @@index([paymentId])
  @@index([txHash])
}

model LedgerEntry {
  id        String   @id @default(uuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id])
  type      String
  side      String
  account   String
  amount    String
  amountRaw BigInt
  currency  String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([account])
}

model WebhookDelivery {
  id        String   @id @default(uuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id])
  event     String
  status    String
  error     String?
  sentAt    DateTime @default(now())

  @@index([paymentId])
}

model ConsentRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyType  String   // 'TERMS' | 'PRIVACY' | 'COOKIES'
  version     String   // date-stamped version e.g. '2026-04-10'
  acceptedAt  DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([userId])
  @@index([policyType])
  @@index([acceptedAt])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  SETTLED
  REFUNDED
  EXPIRED
  FAILED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}
