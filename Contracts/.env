# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the wallet that will deploy the contracts (no 0x prefix needed
# but it's fine to include it). Fund this wallet with AVAX before deploying.
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ── Contract addresses (filled in after deployment) ───────────────────────────
PAYMENT_GATEWAY_ADDRESS=
MERCHANT_REGISTRY_ADDRESS=

# ── USDC token addresses ──────────────────────────────────────────────────────
# Fuji testnet USDC  (Aave test token — free to mint)
# USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
# Mainnet USDC
USDC_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E

# ── Treasury ──────────────────────────────────────────────────────────────────
# The founder multisig / Safe wallet that receives protocol fees.
# All USDC fees accumulate on-chain until withdrawTreasury() is called.
TREASURY_ADDRESS=0x_YOUR_MULTISIG_ADDRESS_HERE

# ── Protocol fee ──────────────────────────────────────────────────────────────
# Default fee in basis points. 150 = 1.5%, 100 = 1%, 200 = 2%
# Individual merchants can have a lower custom override set per-merchant.
PROTOCOL_FEE_BPS=150

# ── Block explorer verification ───────────────────────────────────────────────
# Get a free key at https://snowtrace.io/register
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_API_KEY

# ── Gas reporter ──────────────────────────────────────────────────────────────
REPORT_GAS=false
